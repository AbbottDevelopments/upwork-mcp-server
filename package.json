{
  "name": "upwork-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Upwork API — agentic-first job discovery, client intelligence, and freelancer workflow tools",
  "type": "module",
  "bin": {
    "upwork-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "auth": "node dist/index.js auth",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "upwork",
    "ai",
    "claude",
    "freelancer",
    "model-context-protocol"
  ],
  "author": "Abbott Developments",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0"
  }
}
